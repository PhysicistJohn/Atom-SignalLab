      "result": "status"
    },
    {
      "method": "select_profile",
      "stateChange": true,
      "result": "status"
    },
    {
      "method": "configure_channel",
      "stateChange": true,
      "result": "status"
    },
    {
      "method": "configure_custom_waveform",
      "stateChange": true,
      "result": "status"
    },
    {
      "method": "acquire_spectrum",
      "stateChange": false,
      "result": "swept-spectrum"
    },
    {
      "method": "acquire_detected_power",
      "stateChange": false,
      "result": "detected-power-timeseries"
    },
    {
      "method": "acquire_iq",
      "stateChange": false,
      "result": "complex-iq"
    },
    {
      "method": "shutdown",
      "stateChange": true,
      "result": "shutdown"
    }
