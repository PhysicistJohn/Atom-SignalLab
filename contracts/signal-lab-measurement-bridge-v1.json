    "configurationRevision": "opaque-and-replaced-after-every-accepted-configuration-change",
    "detectedPowerTuning": "required-safe-integer-center-hz-returned-exactly-and-receiver-filtered-at-that-tune",
    "complexIqEncoding": "canonical-base64-of-interleaved-cf32le-with-exact-byte-geometry-and-sha256",
    "complexIqCentering": "requested-center-hz-is-the-complex-envelope-reference-and-profile-components-may-have-baseband-offsets",
    "complexIqBandwidth": "independent-safe-integer-hz-no-greater-than-sample-rate-two-sided-minus-3db-span-of-bounded-first-order-real-coefficient-low-pass-initialized-from-first-sample",
    "complexIqUndersampling": "wideband-standards-engineering-profiles-may-be-deterministically-aliased-below-their-catalogued-occupied-support",
    "complexIqChannel": "replay-channel-configuration-is-not-applied-to-clean-analytic-iq-v1",
    "complexIqAvailability": "all-closed-catalog-profiles-with-standards-labelled-results-explicitly-non-conformance",
    "scalarMeasurementQualification": "synthetic-visual-projection-not-a-conformance-vector",
