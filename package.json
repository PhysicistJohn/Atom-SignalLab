{
  "name": "tinysa-signal-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "main": "dist/main/main-process.js",
  "bin": {
    "tinysa-signal-lab-atomizer-bridge": "dist/bridge/atomizer-bridge.js"
  },
  "files": [
    "dist/bridge",
    "contracts/signal-lab-measurement-bridge-v1.json"
  ],
  "scripts": {
    "dev": "npm run build:main && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 concurrently -k \"vite --port 5174\" \"wait-on http://localhost:5174 && electron .\"",
    "build:main": "tsup src/main-process.ts --format esm --out-dir dist/main --external electron && tsup src/preload.ts --format cjs --out-dir dist/main --external electron",
    "build:bridge": "node scripts/build-atomizer-bridge.mjs",
    "bridge": "node scripts/run-atomizer-bridge.mjs",
    "build": "npm run build:main && npm run build:bridge && vite build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:bridge",
    "test": "vitest run",
    "check": "npm run typecheck && npm run build && npm test",
    "package:mac": "npm run build && electron-builder --mac dmg zip",
    "package:win": "npm run build && electron-builder --win nsis portable",
    "package:linux": "npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.0.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.3",
    "cross-env": "10.1.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "tsup": "8.5.0",
    "typescript": "5.9.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wait-on": "9.0.3"
  },
  "engines": { "node": ">=22", "npm": "10.9.8" },
  "build": {
    "appId": "com.physicistjohn.atomos-signallab",
    "productName": "TinySA SignalLab",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "-",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "target": ["AppImage"]
    }
  }
}
